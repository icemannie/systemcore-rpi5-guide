# Large binary files (not tracked in git)
*.img
*.zip
*.deb
*.tar.gz
*.tar.xz

# Kernel source tree (cloned by build-kernel.sh)
rpi-linux/

# Build output
output/
cache/

# NFS root and TFTP boot files (generated)
netboot/nfsroot/
netboot/rootfs.img
netboot/tftpboot/

# Upstream source reference
systemcore-os-public-*/

# Claude Code local settings
.claude/

# Python bytecode (from the patcher package)
__pycache__/
*.pyc
